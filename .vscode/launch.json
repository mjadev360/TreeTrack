{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/TreeTrack.Server/bin/Debug/net10.0/TreeTrack.Server.dll",
            "cwd": "${workspaceFolder}/TreeTrack.Server",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "stopAtEntry": false,
            "launchSettingsFilePath": "${workspaceFolder}/TreeTrack.Server/Properties/launchSettings.json",
            "launchSettingsProfile": "https",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "➜\\s+Local:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7230;http://localhost:5239",
                "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
